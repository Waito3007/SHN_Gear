.vscode/

# Logs
*.log

# Build results
bin/
obj/

# Rider project files
.idea/
*.iml

# NuGet Packages
*.nupkg

# Backup & report files
*.bak
*.swp
*.tmp
*.temp
*.tmp
*.temp
*.log
*.tlog
*.log
*.tlog

# Docker
**/Dockerfile
**/docker-compose.yml
**/.dockerignore

# Sensitive configuration files
**/appsettings.json
**/appsettings.Development.json
**/launchSettings.json

# Entity Framework Migrations
**/Migrations/


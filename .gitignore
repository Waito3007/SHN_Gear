coverage/
*.coverage
*.coveragexml

# Ignore other unnecessary files
.DS_Store
Thumbs.db

# Ensure SANBGLog/bin is ignored
SANBGLog/bin/

# Ignore log files specifically in SANBGLog
SANBGLog/*.log

# Ensure SHNGearBE/bin is ignored
SHNGearBE/bin/

# Ignore log files specifically in SHNGearBE
SHNGearBE/*.log

# Ignore env
.env
# Ensure obj folders are ignored
**/obj/
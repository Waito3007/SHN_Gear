{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Username=admin;Password=123456;Database=SHNGear;Pooling=true;SSl Mode=Disable"
  },
  "BackgroundLogServiceConfig": {
    "ProjectName": "SHNGearBE",
    "LogDirectory": "Logs",
    "MaxFileSizeBytes": 4194304,
    "FlushIntervalSeconds": 5,
    "FilterLogBySources": {
      "SHNGearBE": {
        "IgnoreByMethodList": [
          "HealthCheck",
          "Ping"
        ],
        "FilterList": [
          {
            "PrototypeList": [
              "Password",
              "Token",
              "SecretKey"
            ],
            "Type": 1
          },
          {
            "PrototypeList": [
              "PhoneNumber"
            ],
            "Type": 2,
            "Start": 3,
            "End": 3
          }
        ]
      }
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "SHNGear_",
    "DefaultExpirationMinutes": 30
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  }
}
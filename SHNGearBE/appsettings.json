{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Username=admin;Password=123456;Database=SHNGear;Pooling=true;SSl Mode=Disable"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLongForHS256Algorithm",
    "Issuer": "SHNGear",
    "Audience": "SHNGearAPI",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "BackgroundLogServiceConfig": {
    "ProjectName": "SHNGearBE",
    "LogDirectory": "Logs",
    "MaxFileSizeBytes": 4194304,
    "FlushIntervalSeconds": 5,
    "FilterLogBySources": {
      "SHNGearBE": {
        "IgnoreByMethodList": [
          "HealthCheck",
          "Ping"
        ],
        "FilterList": [
          {
            "PrototypeList": [
              "Password",
              "Token",
              "SecretKey"
            ],
            "Type": 1
          },
          {
            "PrototypeList": [
              "PhoneNumber"
            ],
            "Type": 2,
            "Start": 3,
            "End": 3
          }
        ]
      }
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false,connectTimeout=5000",
    "InstanceName": "SHNGear_",
    "DefaultExpirationMinutes": 30
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": ""
  },
  "EmailService": {
    "Provider": "Smtp",
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromDisplayName": "SHNGear",
    "TimeoutSeconds": 30
  },
  "PayPal": {
    "BaseUrl": "https://api-m.sandbox.paypal.com",
    "ClientId": "",
    "ClientSecret": "",
    "WebhookId": "",
    "CurrencyCode": "USD",
    "ExchangeRateApiBaseUrl": "https://v6.exchangerate-api.com",
    "ExchangeRateApiKey": "",
    "FallbackVndPerUsdRate": 25500,
    "HttpTimeoutSeconds": 20
  }
}